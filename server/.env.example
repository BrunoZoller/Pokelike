# Copy to .env and fill in values

# Secret used to sign JWTs — use a long random string, never commit this
ANTICHEAT_SECRET=replace-with-a-long-random-secret

# Port the server listens on
PORT=3001

# CORS origin — set to your game's domain in production
ALLOWED_ORIGIN=https://pokelike.xyz

# Path to SQLite database file
DB_PATH=./pokelike-ac.db
